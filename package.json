{
  "private": true,
  "name": "server-slime",
  "version": "0.0.1",
  "description": "server-slime with Colyseus",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed": "tsx src/utils/seed.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "yarn clean && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node build/index.js",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "author": "Anna",
  "license": "UNLICENSED",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/sdk": "^0.17.17",
    "@colyseus/testing": "^0.17.10",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "@types/seedrandom": "^3.0.8",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4"
  },
  "resolutions": {
    "uWebSockets.js": "https://github.com/uNetworking/uWebSockets.js/archive/refs/tags/v20.56.0.tar.gz"
  },
  "dependencies": {
    "@colyseus/command": "^0.3.2",
    "@colyseus/redis-driver": "^0.17.7",
    "@colyseus/schema": "^4.0.0",
    "@colyseus/tools": "^0.17.0",
    "@colyseus/uwebsockets-transport": "0.17.20",
    "bcryptjs": "^3.0.3",
    "colyseus": "^0.17.6",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "redis": "^5.12.1",
    "seedrandom": "^3.0.5",
    "uwebsockets-express": "^1.4.2",
    "zod": "^4.3.6"
  }
}
